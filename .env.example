# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (standard or Prisma Postgres format).
# Example (standard):  postgresql://user:password@localhost:5432/superlog
# Example (Prisma PG): prisma+postgres://localhost:51213/?api_key=<key>
DATABASE_URL="postgresql://user:password@localhost:5432/superlog"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# The canonical URL of your deployment (no trailing slash).
# In development this is typically http://localhost:3000.
NEXTAUTH_URL="http://localhost:3000"

# A long, random secret used to sign JWTs and session cookies.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-strong-random-secret"

# ─── GitHub OAuth App ────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_ID="your-github-oauth-app-client-id"
GITHUB_SECRET="your-github-oauth-app-client-secret"

# ─── GitHub Webhook ──────────────────────────────────────────────────────────
# Secret token configured on the GitHub webhook to validate incoming payloads.
# Generate one with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET="replace-me-with-a-strong-random-secret"

# ─── Cron Jobs ───────────────────────────────────────────────────────────────
# Bearer token used to authenticate requests to /api/cron/* endpoints.
# Generate one with: openssl rand -hex 32
CRON_SECRET="replace-me-with-a-strong-random-secret"
